{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the PMO system, either an Admin or a Resource.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "resource"] }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A project containing all PMO assets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "metadata": {
          "type": "object",
          "properties": {
            "projectName": { "type": "string" },
            "preparedBy": { "type": "string" },
            "date": { "type": "string" },
            "organization": { "type": "string" },
            "projectSpace": { "type": "string", "enum": ["R&D", "Delivery"] },
            "prioritizationProcess": { "type": "string", "enum": ["Idea", "POC", "MVP", "Delivery"] }
          }
        },
        "summary": { "type": "string" },
        "wbs": { "type": "array", "items": { "type": "object" } },
        "hld": { "type": "array", "items": { "type": "object" } },
        "lld": { "type": "array", "items": { "type": "object" } },
        "roadmap": { "type": "array", "items": { "type": "object" } },
        "activities": { "type": "array", "items": { "type": "object" } },
        "riskLog": { "type": "array", "items": { "type": "object" } },
        "backlog": { "type": "array", "items": { "type": "object" } },
        "sprints": { "type": "array", "items": { "type": "object" } },
        "resources": { "type": "array", "items": { "type": "object" } },
        "assignedEmails": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "object" } },
        "weeklyStatus": { "type": "object" },
        "lastUpdated": { "type": "string" },
        "isArchived": { "type": "boolean" },
        "ownerId": { "type": "string", "description": "UID of the admin who created the project" }
      },
      "required": ["id", "metadata", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project data and assets."
    }
  }
}
